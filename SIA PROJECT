<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<title>SIGNAL</title>
<style>
  :root{
    --bg: #0e0e18;
    --bg2: #14141f;
    --cyan: #00e5ff;
    --cyan-dim: #0a5a66;
    --violet: #3d3d63;
    --violet-soft: #23233a;
    --coral: #ff6b6b;
    --text: #eef0f7;
    --text-dim: #7c7c99;
  }
  *{ box-sizing:border-box; }
  html,body{
    margin:0; height:100%;
    background: radial-gradient(ellipse at 50% 30%, #16162a 0%, var(--bg) 70%);
    font-family: -apple-system, 'Segoe UI', system-ui, sans-serif;
    color: var(--text);
    overflow:hidden;
  }
  body{
    display:flex; align-items:center; justify-content:center;
    min-height:100vh;
    padding: 20px;
  }
  .stage{
    width: 100%;
    max-width: 380px;
    display:flex; flex-direction:column; align-items:center;
    gap: 28px;
  }
  .brand{
    font-size: 13px;
    font-weight: 700;
    letter-spacing: 6px;
    color: var(--text-dim);
  }
  .brand span{ color: var(--cyan); }
 
  .ring-wrap{
    position: relative;
    width: 300px;
    height: 300px;
  }
  .ring-wrap.idle{ animation: slowspin 40s linear infinite; }
  @keyframes slowspin{ to{ transform: rotate(360deg); } }
 
  .pad{
    position:absolute;
    width: 108px; height: 108px;
    border-radius: 50%;
    background: var(--violet-soft);
    border: 2px solid var(--violet);
    cursor: pointer;
    transition: background 0.15s, border-color 0.15s, transform 0.08s;
  }
  .pad:active{ transform: scale(0.96); }
  .pad.n0{ top: 0; left: 96px; }
  .pad.n1{ top: 96px; left: 192px; }
  .pad.n2{ top: 192px; left: 96px; }
  .pad.n3{ top: 96px; left: 0; }
 
  .pad.lit{
    background: var(--cyan);
    border-color: var(--cyan);
    box-shadow: 0 0 30px 6px rgba(0,229,255,0.55);
  }
  .pad.wrong{
    background: var(--coral);
    border-color: var(--coral);
    box-shadow: 0 0 30px 6px rgba(255,107,107,0.55);
  }
 
  .pulse{
    position:absolute;
    inset: 0;
    border-radius: 50%;
    border: 2px solid var(--cyan);
    opacity: 0;
    pointer-events:none;
  }
  .pulse.go{
    animation: pulseout 0.55s ease-out;
  }
  @keyframes pulseout{
    0%{ transform: scale(1); opacity: 0.8; }
    100%{ transform: scale(1.7); opacity: 0; }
  }
 
  .hub{
    position:absolute;
    top: 50%; left: 50%;
    transform: translate(-50%,-50%);
    width: 120px; height: 120px;
    border-radius: 50%;
    background: var(--bg2);
    border: 1px solid var(--violet);
    display:flex; flex-direction:column;
    align-items:center; justify-content:center;
    text-align:center;
    z-index: 2;
  }
  .hub .level{
    font-size: 34px;
    font-weight: 800;
    color: var(--cyan);
    line-height: 1;
  }
  .hub .label{
    font-size: 9px;
    letter-spacing: 2px;
    color: var(--text-dim);
    margin-top: 4px;
  }
 
  .status{
    font-size: 13px;
    color: var(--text-dim);
    letter-spacing: 1px;
    height: 18px;
    text-align: center;
  }
  .status.watch{ color: var(--cyan); }
  .status.go{ color: var(--text); }
  .status.fail{ color: var(--coral); }
 
  .controls{
    display:flex; gap: 12px;
  }
  .btn{
    font-family: inherit;
    font-weight: 700;
    font-size: 13px;
    letter-spacing: 1.5px;
    padding: 12px 26px;
    border-radius: 30px;
    border: none;
    cursor: pointer;
    transition: transform 0.08s, opacity 0.15s;
  }
  .btn:active{ transform: scale(0.97); }
  .btn.start{
    background: var(--cyan);
    color: #06181c;
  }
  .btn.stop{
    background: transparent;
    color: var(--text-dim);
    border: 1px solid var(--violet);
  }
  .btn.stop:hover{ color: var(--coral); border-color: var(--coral); }
  .btn[disabled]{ opacity: 0.35; cursor: default; }
 
  .best{
    font-size: 11px;
    color: var(--text-dim);
    letter-spacing: 1px;
  }
  .best b{ color: var(--text); }
 
  @media (max-width: 360px){
    .ring-wrap{ width: 250px; height: 250px; }
    .pad{ width: 90px; height: 90px; }
    .pad.n1{ left: 160px; top: 80px; }
    .pad.n2{ left: 80px; top: 160px; }
    .hub{ width: 100px; height: 100px; }
  }
</style>
</head>
<body>
<div class="stage">
  <div class="brand">S I G N <span>A</span> L</div>
 
  <div class="ring-wrap idle" id="ringWrap">
    <div class="pad n0" data-n="0"><div class="pulse" data-p="0"></div></div>
    <div class="pad n1" data-n="1"><div class="pulse" data-p="1"></div></div>
    <div class="pad n2" data-n="2"><div class="pulse" data-p="2"></div></div>
    <div class="pad n3" data-n="3"><div class="pulse" data-p="3"></div></div>
    <div class="hub">
      <div class="level" id="level">--</div>
      <div class="label" id="hubLabel">READY</div>
    </div>
  </div>
 
  <div class="status" id="status">watch, then repeat the pattern</div>
 
  <div class="controls">
    <button class="btn start" id="startBtn">START</button>
    <button class="btn stop" id="stopBtn" disabled>STOP</button>
  </div>
 
  <div class="best">BEST: <b id="best">0</b></div>
</div>
 
<script>
const pads = document.querySelectorAll('.pad');
const pulses = document.querySelectorAll('.pulse');
const levelEl = document.getElementById('level');
const hubLabel = document.getElementById('hubLabel');
const statusEl = document.getElementById('status');
const startBtn = document.getElementById('startBtn');
const stopBtn = document.getElementById('stopBtn');
const bestEl = document.getElementById('best');
const ringWrap = document.getElementById('ringWrap');
 
let sequence = [];
let playerStep = 0;
let level = 0;
let best = 0;
let playing = false;
let acceptingInput = false;
 
function lightPad(n, cls='lit', dur=380){
  const pad = document.querySelector(`.pad.n${n}`);
  const pulse = document.querySelector(`.pulse[data-p="${n}"]`);
  pad.classList.add(cls);
  pulse.classList.remove('go'); void pulse.offsetWidth; pulse.classList.add('go');
  return new Promise(res=>{
    setTimeout(()=>{
      pad.classList.remove(cls);
      res();
    }, dur);
  });
}
 
function sleep(ms){ return new Promise(res=>setTimeout(res, ms)); }
 
async function playSequence(){
  acceptingInput = false;
  hubLabel.textContent = 'WATCH';
  statusEl.textContent = 'watch the pattern';
  statusEl.className = 'status watch';
  await sleep(500);
  for(const n of sequence){
    await lightPad(n);
    await sleep(180);
  }
  acceptingInput = true;
  playerStep = 0;
  hubLabel.textContent = 'YOUR TURN';
  statusEl.textContent = 'repeat it back';
  statusEl.className = 'status go';
}
 
function nextRound(){
  level++;
  levelEl.textContent = level;
  sequence.push(Math.floor(Math.random()*4));
  playSequence();
}
 
function startGame(){
  playing = true;
  level = 0;
  sequence = [];
  ringWrap.classList.remove('idle');
  startBtn.disabled = true;
  stopBtn.disabled = false;
  nextRound();
}
 
function endGame(failed){
  playing = false;
  acceptingInput = false;
  ringWrap.classList.add('idle');
  startBtn.disabled = false;
  stopBtn.disabled = true;
  if(failed){
    statusEl.textContent = `signal lost at level ${level}`;
    statusEl.className = 'status fail';
  } else {
    statusEl.textContent = 'stopped — press start to try again';
    statusEl.className = 'status';
  }
  hubLabel.textContent = 'READY';
  levelEl.textContent = '--';
  if(level > best){
    best = level;
    bestEl.textContent = best;
  }
}
 
pads.forEach(pad=>{
  pad.addEventListener('click', async ()=>{
    if(!playing || !acceptingInput) return;
    const n = parseInt(pad.dataset.n);
    const expected = sequence[playerStep];
 
    if(n === expected){
      await lightPad(n, 'lit', 220);
      playerStep++;
      if(playerStep === sequence.length){
        acceptingInput = false;
        hubLabel.textContent = 'NICE';
        statusEl.textContent = 'correct — next level incoming';
        statusEl.className = 'status go';
        await sleep(700);
        if(playing) nextRound();
      }
    } else {
      acceptingInput = false;
      await lightPad(n, 'wrong', 400);
      endGame(true);
    }
  });
});
 
startBtn.addEventListener('click', startGame);
stopBtn.addEventListener('click', ()=> endGame(false));
</script>
</body>
</html>
 
